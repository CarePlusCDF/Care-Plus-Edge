              "raw": "{\n  \"devices\": [\n    {\n      \"device_id\":   \"step001\",\n      \"entity_name\": \"urn:ngsi-ld:Pedometer:001\",\n      \"entity_type\": \"Pedometer\",\n      \"protocol\":    \"PDI-IoTA-UltraLight\",\n      \"transport\":   \"MQTT\",\n      \"commands\": [\n        { \"name\": \"agua\", \"type\": \"command\" }\n      ],\n      \"attributes\": [\n        { \"object_id\": \"p\", \"name\": \"steps\",            \"type\": \"Integer\" },\n        { \"object_id\": \"m\", \"name\": \"steps_per_minute\", \"type\": \"Float\"   },\n        { \"object_id\": \"b\", \"name\": \"button_event\",     \"type\": \"Text\"    }\n      ]\n    }\n  ]\n}"
            },
